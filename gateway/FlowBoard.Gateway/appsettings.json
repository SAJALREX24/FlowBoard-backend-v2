{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
 "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "FlowBoard.Auth",
    "Audience": "FlowBoard.Clients",
    "Key": "SET_VIA_RENDER_ENVIRONMENT_VARIABLE"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "workspace-route": {
        "ClusterId": "workspace-cluster",
        "Match": {
          "Path": "/api/workspaces/{**catch-all}"
        }
      },
      "board-route": {
        "ClusterId": "board-cluster",
        "Match": {
          "Path": "/api/boards/{**catch-all}"
        }
      },
      "list-route": {
        "ClusterId": "list-cluster",
        "Match": {
          "Path": "/api/lists/{**catch-all}"
        }
      },
      "card-route": {
        "ClusterId": "card-cluster",
        "Match": {
          "Path": "/api/cards/{**catch-all}"
        }
      },
      "comment-route": {
        "ClusterId": "comment-cluster",
        "Match": {
          "Path": "/api/comments/{**catch-all}"
        }
      },
      "label-route": {
        "ClusterId": "label-cluster",
        "Match": {
          "Path": "/api/labels/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://127.0.0.1:5048/"
          }
        }
      },
      "workspace-cluster": {
        "Destinations": {
          "workspace-destination": {
            "Address": "http://127.0.0.1:5277/"
          }
        }
      },
      "board-cluster": {
        "Destinations": {
          "board-destination": {
            "Address": "http://127.0.0.1:5030/"
          }
        }
      },
      "list-cluster": {
        "Destinations": {
          "list-destination": {
            "Address": "http://127.0.0.1:5266/"
          }
        }
      },
      "card-cluster": {
        "Destinations": {
          "card-destination": {
            "Address": "http://127.0.0.1:5024/"
          }
        }
      },
      "comment-cluster": {
        "Destinations": {
          "comment-destination": {
            "Address": "http://127.0.0.1:5198/"
          }
        }
      },
      "label-cluster": {
        "Destinations": {
          "label-destination": {
            "Address": "http://127.0.0.1:5027/"
          }
        }
      }
    }
  }
}
